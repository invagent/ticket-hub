# Copy to .env and fill in real values for local dev / UAT.
# DO NOT commit .env. .gitignore covers it.

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ---- Auth ----
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=28800

# ---- Postgres / Redis / S3 (docker-compose defaults) ----
PG_DSN=postgresql+psycopg://hub:hub@localhost:5432/ticket_hub
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ticket-hub-attachments

# ---- Feishu ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_SSO_REDIRECT_URI=http://localhost:8080/api/auth/feishu/callback

# ---- KSM ----
KSM_BASE_URL=https://ierpuat.kingdee.com
KSM_APP_ID=
KSM_APP_SECRET=
KSM_TENANT_ID=
KSM_ACCOUNT_ID=
KSM_USER=

# ---- Zhichi ----
ZHICHI_APPID=
ZHICHI_APP_KEY=

# ---- LLM Providers (D3 onwards) ----
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GLM_API_KEY=

# ---- PII ----
PII_MASTER_KEY=

# ---- Webhook ----
WEBHOOK_ACCESS_TOKEN=
