# Copy to .env and fill in real values for local dev / UAT.
# DO NOT commit .env. .gitignore covers it.

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ---- Auth ----
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=28800

# ---- Postgres / Redis / S3 (docker-compose defaults) ----
PG_DSN=postgresql+psycopg://hub:hub@localhost:5432/ticket_hub
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ticket-hub-attachments

# ---- Feishu ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_SSO_REDIRECT_URI=http://localhost:8080/api/auth/feishu/callback
# 旧版 bitable 存储（D1 值班表 seed 用；D6 退役，可留空）
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
FEISHU_DUTY_TABLE_ID=

# ---- KSM ----
# 入站三步鉴权（getAppToken→login→access_token）。生产 base 用 ierp.kingdee.com，UAT 用 ierpuat
KSM_BASE_URL=https://ierpuat.kingdee.com
KSM_APP_ID=
KSM_APP_SECRET=
KSM_TENANT_ID=
KSM_ACCOUNT_ID=
KSM_USER=
# ---- KSM 出站回写（D4 第②段，Phase 2）----
# 操作员身份（lock/handle/supply 都要带 account/accountName/accountNumber）；未配则整轮跳过
KSM_HANDLER_NAME=
# 处理人工号（accountNumber，飞书员工搜索接口获取）
KSM_HANDLER_NUMBER=
# 回写总开关（默认 false，drain 直接跳过）
KSM_WRITEBACK_ENABLED=
# 灰度：开 enabled 但 dry_run=true → 只组装标 skipped，不真发（默认 true）
KSM_WRITEBACK_DRY_RUN=
# 每轮 drain 处理的 pending 行数上限（默认 20）
KSM_WRITEBACK_BATCH=
# 失败重试上限，超过标 failed 转人工（默认 5）
KSM_WRITEBACK_MAX_ATTEMPTS=

# ---- Zhichi ----
ZHICHI_APPID=
ZHICHI_APP_KEY=

# ---- LLM Providers (D3 onwards) ----
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GLM_API_KEY=
# 可选；默认 glm-4.5-flash。可换 glm-4-flash（免费档）/ glm-4-air / glm-4-plus
GLM_MODEL=
# 阿里云百炼（OpenAI 兼容模式）
DASHSCOPE_API_KEY=
# 可选；默认 deepseek-v4-flash。可换 deepseek-v4-pro / deepseek-v3.2
DASHSCOPE_MODEL=
# 可选；failover 顺序，默认 dashscope,glm（2026-06-11 评测 deepseek-v4-flash 最优）
LLM_PROVIDER_ORDER=

# ---- PII ----
PII_MASTER_KEY=

# ---- Webhook ----
WEBHOOK_ACCESS_TOKEN=
# D3-D split 执行器：自动物化开关（默认 false，先灰度手动）+ 置信度阈值
SPLIT_AUTO_ENABLED=
SPLIT_AUTO_CONFIDENCE=

# ---- D3-E dedup（仅审计不动工单）----
# DEDUP_ENABLED 默认 true；召回阈值/候选数/扫描池见 config.py 默认值
DEDUP_ENABLED=
DEDUP_RECALL_THRESHOLD=
# v2: 90 天内语义重复自动挂 hub（默认关，先灰度审计）+ 窗口天数
DEDUP_AUTO_MOUNT_ENABLED=
DEDUP_MOUNT_WINDOW_DAYS=
# v2: 建 Linear 前 hub 级语义去重（默认开）+ 阈值
HUB_DEDUP_ENABLED=
HUB_DEDUP_THRESHOLD=
# embedding 模型（OpenAI 方言 /embeddings；failover 顺序同 LLM_PROVIDER_ORDER）
DASHSCOPE_EMBEDDING_MODEL=
GLM_EMBEDDING_MODEL=

# ---- D4 hub_issue / Linear ----
# 分类后自动建 hub_issue（默认 false，先灰度主管手动 create-hub-issue）
HUB_ISSUE_AUTO_ENABLED=
HUB_ISSUE_AUTO_CONFIDENCE=
# Bug_fix/Demand hub_issue 创建后推 Linear（默认 false；需 LINEAR_API_KEY+TEAM_ID）
LINEAR_PUSH_ENABLED=
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# ---- D4 第③段 Vision 多模态（截图识别）----
# 默认关；开后 ingest 链在 classify 前对 image 附件 OCR，补进 body
VISION_ENABLED=
# 截图识别模型；默认 qwen-vl-max，可换 qwen-vl-plus 省成本
VISION_MODEL=
# 留空则回落 DASHSCOPE_API_KEY（同 DashScope 边界）
VISION_API_KEY=

# ---- D4 第③段 AI 客服 escalation（不满意转二次分类）----
# 自动毕业 hub_issue 置信门槛（默认关；比普通 0.80 高，因直接推 Linear）
ESCALATION_AUTO_ENABLED=
ESCALATION_AUTO_CONFIDENCE=

# ---- Phase 1 知识反哺闭环：AI 客服 open-api（skill-management.json）----
# 主管从 escalation 工单反思 → 改 skill draft → replay 试跑 → 发布。默认关，
# 配好 base_url + appid/app_key 后开（AI 客服侧 get_token 用 MD5(appid+create_time+app_key) 签名）
KNOWLEDGE_FEEDBACK_ENABLED=
AI_CS_BASE_URL=
AI_CS_APP_ID=
AI_CS_APP_KEY=
AI_CS_MANAGED_SKILLS=customer-service,customer-service-feishu

# ---- D4 优化 v2: SLA 工作日/节假日感知 ----
# 默认关（墙钟）；开后超时判定扣除周末 + holidays 节假日。填好 holidays 日历再开
SLA_WORKDAY_AWARE=

# ---- 路由兜底 ----
# 兜底处理人 user_id（也可在主管工作台配置，DB 优先于此）
DEFAULT_POOL_USER_ID=
