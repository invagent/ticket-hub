# hub-issue SIT env template. Copy to deploy/.env on the server and fill secrets.
# deploy/.env is gitignored — never commit real values.
# PG + Redis are REMOTE managed instances (not in this compose).

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=uat
LOG_LEVEL=INFO

# ---- Auth ----
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=604800

# ---- Remote Postgres / Redis (managed; e.g. 106.55.57.40) ----
PG_DSN=postgresql+psycopg://USER:PASS@HOST:5432/ticket_hub_sit?connect_timeout=10
REDIS_URL=redis://:PASS@HOST:6379/1

# ---- S3 / MinIO ----
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ticket-hub-attachments

# ---- Feishu (SIT app) ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_SSO_REDIRECT_URI=http://43.139.250.182/hub-issue/api/auth/feishu/callback

# ---- KSM (三步鉴权；SIT 未配则留空，回写自动跳过) ----
KSM_BASE_URL=https://ierpuat.kingdee.com
KSM_APP_ID=
KSM_APP_SECRET=
KSM_TENANT_ID=
KSM_ACCOUNT_ID=
KSM_USER=
KSM_HANDLER_NAME=
KSM_HANDLER_NUMBER=
KSM_WRITEBACK_ENABLED=false
KSM_WRITEBACK_DRY_RUN=true

# ---- LLM ----
LLM_PROVIDER_ORDER=dashscope,glm
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=deepseek-v4-flash
GLM_API_KEY=
GLM_MODEL=glm-4.5-flash

# ---- Linear ----
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_PUSH_ENABLED=false

# ---- Phase 1 知识反哺：AI 客服 open-api（默认关，配好 base_url+appid/app_key 后开）----
KNOWLEDGE_FEEDBACK_ENABLED=false
AI_CS_BASE_URL=
AI_CS_APP_ID=
AI_CS_APP_KEY=
AI_CS_MANAGED_SKILLS=customer-service,customer-service-feishu

# ---- Feature switches (gray rollout; all safe defaults) ----
HUB_ISSUE_AUTO_ENABLED=false
HUB_ISSUE_AUTO_CONFIDENCE=0.80
DEDUP_ENABLED=true
CONFLICT_DETECT_ENABLED=true
SPLIT_AUTO_ENABLED=false
VISION_ENABLED=false
ESCALATION_AUTO_ENABLED=false
SLA_WORKDAY_AWARE=false

# ---- Webhook ----
WEBHOOK_ACCESS_TOKEN=
